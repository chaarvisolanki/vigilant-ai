{
  "uri": "http://localhost:8000/chat",
  "method": "post",
  "headers": {
    "Content-Type": "application/json"
  },
  "req_template_json_object": {
    "messages": [
      {"role": "user", "content": "$INPUT"}
    ],
    "model": "llama-3.1-8b-instant",
    "guardrails_enabled": true,
    "temperature": 0.7
  },
  "response_json": true,
  "response_json_field": "$.content",
  "request_timeout": 20
}
